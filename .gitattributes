# Normalize text line endings consistently across platforms.
# Git decides what is text; the rules below override that decision where needed.
* text=auto

# Keep R / Quarto / Markdown / config sources as LF (avoids CRLF churn on Windows).
*.R          text eol=lf
*.qmd        text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.csv        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# Treat these as binary: never apply line-ending or text conversion.
*.pdf   binary
*.docx  binary
*.pptx  binary
*.ppt   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.woff  binary
*.woff2 binary
*.jar   binary
